---
const { currentPath = '' } = Astro.props;
---
<nav class="site-nav" aria-label="Main">
  <div class="nav-inner container">
    <a href="/" class="nav-logo">
      <span class="logo-dot" aria-hidden="true">◆</span> DNSSnuff
    </a>
    <ul class="nav-links" id="nav-links">
      <li><a href="/features" class={currentPath === '/features' ? 'active' : ''}>Features</a></li>
      <li><a href="/pricing" class={currentPath === '/pricing' ? 'active' : ''}>Pricing</a></li>
      <li class="nav-dropdown">
        <button type="button" class="nav-parent" aria-expanded="false" aria-controls="use-cases-dropdown">Use Cases</button>
        <ul class="dropdown" id="use-cases-dropdown">
          <li><a href="/use-cases/developers">Developers</a></li>
          <li><a href="/use-cases/msp">MSPs &amp; Agencies</a></li>
          <li><a href="/use-cases/it-teams">IT Teams</a></li>
        </ul>
      </li>
      <li><a href="/blog" class={currentPath === '/blog' ? 'active' : ''}>Blog</a></li>
      <li><a href="/about" class={currentPath === '/about' ? 'active' : ''}>About</a></li>
    </ul>
    <div class="nav-auth">
      <a href="/auth/sign-in" class="btn-ghost">Sign In</a>
      <a href="/auth/sign-up" class="btn btn-primary btn-sm">Sign Up Free</a>
    </div>
    <button type="button" class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-links">☰</button>
  </div>
</nav>

<style>
.site-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(10,10,15,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.nav-inner {
  display: flex;
  align-items: center;
  gap: 2rem;
  height: 64px;
}
.nav-logo {
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--accent) !important;
  letter-spacing: -0.02em;
  flex-shrink: 0;
  text-decoration: none;
}
.logo-dot { font-size: 0.7em; }
.nav-links {
  display: flex;
  list-style: none;
  gap: 0.25rem;
  flex: 1;
}
.nav-links > li > a,
.nav-parent {
  display: block;
  padding: 0.4rem 0.75rem;
  color: var(--text-muted);
  font-size: 0.9rem;
  font-weight: 500;
  border-radius: 6px;
  transition: color 0.15s;
  cursor: pointer;
}
.nav-parent {
  background: none;
  border: none;
  font-family: inherit;
}
.nav-links > li > a:hover,
.nav-parent:hover { color: var(--text); }
.nav-links > li > a.active { color: var(--accent); }

.nav-dropdown { position: relative; }
.nav-dropdown:hover .dropdown,
.nav-dropdown:focus-within .dropdown,
.nav-dropdown.is-open .dropdown { display: block; }
.dropdown {
  display: none;
  position: absolute;
  top: calc(100% + 0.5rem);
  left: 0;
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0.5rem;
  min-width: 200px;
  list-style: none;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}
.dropdown li a {
  display: block;
  padding: 0.5rem 0.75rem;
  color: var(--text-muted);
  font-size: 0.875rem;
  border-radius: 6px;
}
.dropdown li a:hover { background: var(--bg-3); color: var(--text); }

.nav-auth {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
}
.btn-ghost {
  color: var(--text-muted);
  font-size: 0.875rem;
  font-weight: 500;
  padding: 0.4rem 0.75rem;
  border-radius: 6px;
  transition: color 0.15s;
  text-decoration: none;
}
.btn-ghost:hover { color: var(--text); }
.btn-sm { padding: 0.45rem 1.1rem; font-size: 0.875rem; }

.nav-toggle { display: none; background: none; border: 1px solid var(--border); color: var(--text); padding: 0.35rem 0.65rem; border-radius: 6px; cursor: pointer; font-size: 1rem; margin-left: auto; }

@media (max-width: 768px) {
  .nav-links, .nav-auth { display: none; }
  .nav-toggle { display: block; }
  .nav-links.is-open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 64px;
    left: 0;
    right: 0;
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
    padding: 0.5rem;
  }
  .nav-dropdown .dropdown { position: static; box-shadow: none; }
}
</style>

<script>
const navToggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
const navLinks = document.getElementById('nav-links');

navToggle?.addEventListener('click', () => {
  const isOpen = navLinks?.classList.toggle('is-open');
  navToggle.setAttribute('aria-expanded', String(!!isOpen));
});

document.querySelectorAll<HTMLButtonElement>('.nav-parent').forEach(btn => {
  btn.addEventListener('click', () => {
    const dropdown = btn.closest('.nav-dropdown');
    const isOpen = dropdown?.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(!!isOpen));
  });
});

document.addEventListener('click', (e) => {
  document.querySelectorAll('.nav-dropdown.is-open').forEach(dropdown => {
    if (!dropdown.contains(e.target as Node)) {
      dropdown.classList.remove('is-open');
      dropdown.querySelector('.nav-parent')?.setAttribute('aria-expanded', 'false');
    }
  });
});
</script>
