---
export interface Props {
  title: string;
  description: string;
  currentPath?: string;
  noindex?: boolean;
}
const { title, description, currentPath = '', noindex = false } = Astro.props;
const GA4 = 'G-VL248KXQF9';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="canonical" href={`https://dnssnuff.com${currentPath}`} />

  <!-- Google tag (gtag.js) -->
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4}`}></script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8GEYK7FMK1"></script>
  <script define:vars={{ GA4 }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GA4);
    gtag('config', 'G-8GEYK7FMK1');
  </script>

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://dnssnuff.com${currentPath}`} />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <slot name="nav" />
  <main>
    <slot />
  </main>
  <slot name="footer" />
</body>
</html>
